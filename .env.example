# AI 模型选择：deepseek（默认）| openai
AI_PROVIDER=deepseek

# DeepSeek 配置（默认 Provider，性价比高）
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI 配置（切换 AI_PROVIDER=openai 后生效）
# 兼容 Azure OpenAI / 本地 Ollama 等 OpenAI 兼容服务
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 通用 AI 参数
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.3
AI_TIMEOUT=120
AI_MAX_RETRIES=3

# 文档分块策略
CHUNK_SIZE=3000
CHUNK_OVERLAP=300

# 路径配置
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs

# 数据库
DATABASE_URL=sqlite+aiosqlite:///aitest.db

# 服务端口
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
STREAMLIT_PORT=8501

# 文件上传限制 (MB)
MAX_UPLOAD_SIZE_MB=10
